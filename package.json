{
	"name": "tanstack-start-on-cloudflare",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.1",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"deploy": "pnpm run build && wrangler deploy",
		"serve": "vite preview",
		"cf-typegen": "wrangler types --env-interface Env",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"types": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:ci": "biome ci .",
		"knip": "knip",
		"release": "semantic-release",
		"release:dry": "semantic-release --dry-run",
		"deps": "taze",
		"deps:update": "taze -w",
		"deps:major": "taze major",
		"deps:major:update": "taze major -w",
		"db:dev:generate": "dotenvx run -f .dev.vars -- drizzle-kit generate --config drizzle-dev.config.ts",
		"db:dev:migrate": "dotenvx run -f .dev.vars -- drizzle-kit migrate --config drizzle-dev.config.ts",
		"db:dev:pull": "dotenvx run -f .dev.vars -- drizzle-kit pull --config drizzle-dev.config.ts",
		"db:dev:studio": "dotenvx run -f .dev.vars -- drizzle-kit studio --config drizzle-dev.config.ts",
		"db:dev:seed": "dotenvx run -f .dev.vars -- tsx scripts/seed.ts",
		"db:production:generate": "dotenvx run -f .production.vars -- drizzle-kit generate --config drizzle-production.config.ts",
		"db:production:migrate": "dotenvx run -f .production.vars -- drizzle-kit migrate --config drizzle-production.config.ts",
		"db:production:pull": "dotenvx run -f .production.vars -- drizzle-kit pull --config drizzle-production.config.ts"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/react-form": "^1.29.1",
		"@tanstack/react-query": "^5.99.2",
		"@tanstack/react-query-devtools": "^5.99.2",
		"@tanstack/react-router": "^1.168.23",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/react-router-ssr-query": "^1.166.11",
		"@tanstack/react-start": "^1.167.42",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.14",
		"lucide-react": "^0.476.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"vite-tsconfig-paths": "^5.1.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@cloudflare/vite-plugin": "^1.33.1",
		"@dotenvx/dotenvx": "^1.61.5",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/coverage-v8": "^4.1.5",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^26.1.0",
		"knip": "^6.6.1",
		"semantic-release": "^25.0.3",
		"taze": "^19.11.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "7.1.2",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.5",
		"web-vitals": "^4.2.4",
		"wrangler": "^4.84.1"
	}
}
