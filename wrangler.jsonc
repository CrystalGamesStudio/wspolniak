{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "wspolniak-dev",
	"compatibility_date": "2025-09-02",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./src/server.ts",
	"vars": {
		"APP_URL": "http://192.168.9.14:3000"
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1
	},
	"env": {
		"production": {
			"name": "wspolniak",
			"routes": [{ "pattern": "wspolniak.com", "custom_domain": true }],
			"vars": {
				"APP_URL": "https://wspolniak.com"
			},
			"observability": {
				"enabled": true,
				"head_sampling_rate": 1
			}
		}
	}
}
