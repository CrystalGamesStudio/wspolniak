{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "wspolniak-dev",
	"compatibility_date": "2025-09-02",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./src/server.ts",
	"env": {
		"production": {
			"name": "wspolniak",
			"routes": [{ "pattern": "wspolniak.com", "custom_domain": true }]
		}
	}
}
